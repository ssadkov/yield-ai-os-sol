# Devnet RPC (default is fine for testing)
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com

# Paths to JSON keypairs (relative to client/ or absolute)
OWNER_KEYPAIR=./keys/owner.json
AGENT_KEYPAIR=./keys/agent.json

# Optional: existing SPL mint (e.g. devnet USDC). If unset, the script creates a test mint and mints tokens to the owner.
# MINT=

# Optional: CPI whitelist for initialize (comma-separated program pubkeys, max 16). Required for Jupiter CPI on mainnet.
# Example:
# ALLOWED_PROGRAMS=JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4,TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA
# ALLOWED_PROGRAMS=

# Optional: set to "1" to only run initialize (useful on mainnet before funding USDC).
# SKIP_DEPOSIT_WITHDRAW=1
