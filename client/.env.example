# Devnet RPC (default is fine for testing)
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com

# Paths to JSON keypairs (relative to client/ or absolute)
OWNER_KEYPAIR=./keys/owner.json
AGENT_KEYPAIR=./keys/agent.json

# Optional: existing SPL mint (e.g. devnet USDC). If unset, the script creates a test mint and mints tokens to the owner.
# MINT=
